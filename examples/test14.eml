type Shape = Square as int | Rect as {w : int, h : int};

let a = Square(2) as Shape;
let b = Rect({w = 3, h = 4}) as Shape;

let area : Shape -> int =
  fun (s : Shape) ->
    case s of 
    | <Square=r> => r * r 
    | <Rect=dim> => dim.w * dim.h;

let resultA : int = area(a);
let resultB : int = area(b);