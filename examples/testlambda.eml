type ty =
  TNat as unit
| TBool as unit
| TArrow as {arg : ty, ret : ty};

type exp =
  Var as string
| Lam as {name : string, argT : ty, body : exp}
| App as {funcE : exp, argE : exp}
| Nat as int;

type maybeExp =
    Just as exp
| Error as string;

type maybeTy =
    TyOk as ty
| TyError as string;

type tyCtx =
    CtxNil as int
| CtxCons as {name : string, entryT : ty, rest : tyCtx};

let subst : string -> exp -> exp -> exp =
    fix go. fun (name : string) (value : exp) (e : exp) -> (
        case e of
        | <Var = v> =>
            if (v == name) then
                value
            else
                Var(v) as exp
        
        | <Lam = l> =>
            if (l.name == name) then
                Lam({name = l.name, argT = l.argT, body = l.body}) as exp
            else
                Lam({name = l.name, argT = l.argT, body = go(name)(value)(l.body)}) as exp
        | <App = a> =>
            App({
                funcE = go(name)(value)(a.funcE),
                argE = go(name)(value)(a.argE)
            }) as exp
        | <Nat = n> => Nat(n) as exp
    );

let eval : exp -> maybeExp =
    fix go. fun (e : exp) -> (
        case e of
        | <Var = v> => Error("Runtime error: unbound variable") as maybeExp
        | <Lam = l> => Just(e) as maybeExp
        | <Nat = n> => Just(e) as maybeExp
        | <App = a> => 
            case go(a.funcE) of
            | <Error = errF> => Error(errF) as maybeExp
            | <Just = funcVal> =>
                case go(a.argE) of
                | <Error = errA> => Error(errA) as maybeExp
                | <Just = argVal> => 
                    case funcVal of
                    | <Lam = f> => go(subst (f.name) (argVal) (f.body))
                    | _ => Error("Runtime error: head of application is not a lambda") as maybeExp
                     
    );

let lookupTy : string -> tyCtx -> maybeTy =
    fix go. fun (name : string) (ctx : tyCtx) -> (
        case ctx of
        | <CtxNil = n> => TyError("Type error: variable not found in context") as maybeTy
        | <CtxCons = c> =>
            if (c.name == name) then
                TyOk(c.entryT) as maybeTy
            else
                go(name)(c.rest)
    );

let extendCtx : string -> ty -> tyCtx -> tyCtx =
    fun (name : string) (entryT : ty) (rest : tyCtx) ->
        CtxCons({name = name, entryT = entryT, rest = rest}) as tyCtx;

let typeCheck : tyCtx -> exp -> maybeTy =
    fix go. fun (ctx : tyCtx) (e : exp) -> (
        case e of
        | <Var = v> => lookupTy(v)(ctx)
        | <Nat = n> => TyOk(TNat(()) as ty) as maybeTy
        | <Lam = l> => (
            case go(extendCtx(l.name)(l.argT)(ctx))(l.body) of
            | <TyOk = bodyT> =>
                TyOk(TArrow({arg = l.argT, ret = bodyT}) as ty) as maybeTy
            | <TyError = err> => TyError(err) as maybeTy
        )
        | <App = a> =>
            case go(ctx)(a.funcE) of
            | <TyError = errF> => TyError(errF) as maybeTy
            | <TyOk = funcT> =>
                case go(ctx)(a.argE) of
                | <TyError = errA> => TyError(errA) as maybeTy
                | <TyOk = argT> =>
                    case funcT of
                    | <TArrow = arr> =>
                        if arr.arg == argT then
                            TyOk(arr.ret) as maybeTy
                        else
                            TyError("Type error: argument type mismatch") as maybeTy
                    | _ => TyError("Type error: attempted to apply a non-function") as maybeTy
    );

