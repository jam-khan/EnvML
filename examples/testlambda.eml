let eval : expr -> expr =
fix go.
  fun (e : expr) ->
    case e of
    | <Var = ignored> => RuntimeErr("free variable during evaluation") as expr
    | <Abs = ignored> => e
    | <BoolLit = ignored> => e
    | <NatLit = ignored> => e
    | <App = ap> =>
        (case go(ap.fn) of
        | <RuntimeErr = msgf> => RuntimeErr(msgf) as expr
        | <Abs = a> =>
            (case go(ap.arg) of
            | <RuntimeErr = msga> => RuntimeErr(msga) as expr
            | <Var = argValVar> => go(subst(a.param)(Var(argValVar) as expr)(a.body))
            | <Abs = argValAbs> => go(subst(a.param)(Abs(argValAbs) as expr)(a.body))
            | <App = argValApp> => go(subst(a.param)(App(argValApp) as expr)(a.body))
            | <Let = argValLet> => go(subst(a.param)(Let(argValLet) as expr)(a.body))
            | <BoolLit = argValBool> => go(subst(a.param)(BoolLit(argValBool) as expr)(a.body))
              | <NatLit = argValNat> => go(subst(a.param)(NatLit(argValNat) as expr)(a.body))
              | <If = argValIf> => go(subst(a.param)(If(argValIf) as expr)(a.body))
              | <Record = argValRecord> => go(subst(a.param)(Record(argValRecord) as expr)(a.body))
              | <Proj = argValProj> => go(subst(a.param)(Proj(argValProj) as expr)(a.body)))
          | <Var = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <App = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <Let = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <BoolLit = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <NatLit = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <If = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <Record = ignored> => RuntimeErr("cannot apply non-function") as expr
          | <Proj = ignored> => RuntimeErr("cannot apply non-function") as expr)
      | <Let = l> =>
          go(App({
            fn = Abs({param = l.name, paramTy = TNat(0) as ty, body = l.body}) as expr,
            arg = l.value
          }) as expr)
      | <If = i> =>
          (case go(i.cond) of
          | <RuntimeErr = msg> => RuntimeErr(msg) as expr
          | <BoolLit = b> => if b then go(i.thenE) else go(i.elseE)
          | <Var = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <Abs = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <App = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <Let = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <NatLit = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <If = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <Record = ignored> => RuntimeErr("if condition must evaluate to bool") as expr
          | <Proj = ignored> => RuntimeErr("if condition must evaluate to bool") as expr)
      | <Record = ignored> => RuntimeErr("record evaluation not implemented in this STLC demo") as expr
      | <Proj = ignored> => RuntimeErr("record projection not implemented in this STLC demo") as expr
      | <RuntimeErr = ignored> => e;

let natTy : ty = TNat(0) as ty;

let idNat : expr =
  Abs({
    param = "x",
    paramTy = natTy,
    body = Var("x") as expr
  }) as expr;

let constTrue : expr =
  Abs({
    param = "x",
    paramTy = natTy,
    body = BoolLit(true) as expr
  }) as expr;

let testGood : expr =
  App({
    fn = idNat,
    arg = NatLit(42) as expr
  }) as expr;

let testBad : expr =
  App({
    fn = idNat,
    arg = BoolLit(false) as expr
  }) as expr;

let testIf : expr =
  If({
    cond = BoolLit(true) as expr,
    thenE = NatLit(1) as expr,
    elseE = NatLit(2) as expr
  }) as expr;

let tyGood : ty = infer(emptyCtx)(testGood);
let evGood : expr = eval(testGood);

let tyBad : ty = infer(emptyCtx)(testBad);

let tyIf : ty = infer(emptyCtx)(testIf);
let evIf : expr = eval(testIf);
