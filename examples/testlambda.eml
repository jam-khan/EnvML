type ty =
  TBool as bool
| TNat as int
| TArrow as {arg : ty, ret : ty}

type exp =
  Var as string
| Lam as {argE : exp, argT : ty, body : exp}
| App as {funcE : exp, argE : exp}
| Let as {name : string, val : exp, body : exp};

type ctx =
  CtxEmpty as int
| CtxBind as {name : string, valueTy : ty, rest : ctx};

let emptyCtx : ctx = CtxEmpty(0) as ctx;

