let substExample = box [
  body = App({funcE = Var("x") as exp, argE = Var("y") as exp}) as exp,
  lam = Lam({name = "y", argT = TNat(()) as ty, body = body}) as exp, 
  target = App({funcE = lam, argE = Var("y") as exp}) as exp, 
  value = Nat(42) as exp,
  subst = subst
] in
-- ***** human readable version *****
-- target == (fun(y : nat) -> x(y)) (y)
-- value == 42
subst ("y") (value) (target);


------ ========== eval and check test ==========
let emptyTyCtx = CtxNil(0) as tyCtx;

let checkExample = box [
  body = App({funcE = Var("x") as exp, argE = Var("y") as exp}) as exp,
  funY = Lam({name = "y", argT = TNat(()) as ty, body = body}) as exp, 
  funX = Lam({name = "x", argT = TArrow ({arg = TNat(()) as ty, ret = TNat(()) as ty}) as ty, body = funY}) as exp,
  id = Lam({name = "x", argT = TNat(()) as ty, body = Var("x") as exp}) as exp, 
  two = Nat(2) as exp,
  
  app1 = App ({funcE = funX, argE = id}) as exp,
  app2 = App ({funcE = app1, argE = two}) as exp,

  typeCheck = typeCheck,
  eval = eval,
  emptyTyCtx = emptyTyCtx
] in 
-- ***** human readable version ******
-- app2 == (fun (x : nat -> nat) -> fun (y : nat) -> x(y)) (fun (x : nat) -> x) (2)
[
    typeCheckRes = typeCheck (emptyTyCtx) (app2),
    evalRes = eval (app2)
];
