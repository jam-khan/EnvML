
module type Library = sig
    val inc : int -> int
end;;

module SimpleLib = struct
    let inc = fun (x:int) -> x + 1
end;;

let lib = (module SimpleLib : Library);;

let module L = (val lib : Library) in
  open L in
    inc(1);;

let calc_with (module L : Library) = 
        fun (y:int) -> L.inc(y);;

