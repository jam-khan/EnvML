module type Database = sig
    val name : string;;
    val execute  : string -> string
end;;

let postgres_connect = 
    fun (host: string) (db_name : string) ->
        (module struct
            let name = "PostgreSQL"
            let execute = 
                fun (query : string) -> "PostgreSQL: Done."
        end : Database);;

let mysql_connect =
    fun (host: string) (db_name : string) ->
        (module struct
            let name = "MySQL"
            let execute query =
                fun (query : string) -> "MySQL: Done."
        end : Database);;
