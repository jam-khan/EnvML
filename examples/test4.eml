let result1 : [int] = comp({f = foo(policy1).trans, x = 42});
let result2 : [int] = comp({f = foo(policy2).trans, x = 42});

let comp : {f : int -> [int]} -> [int] = 
    fun (env) -> box [e = env] in e.f(e.x);

module foo : POLICY ->m FOO =
  functor (m : POLICY) ->
    struct
      let trans : a -> [a] = (m @ int).trans;
      type a = int;
    end;

module policy1 : POLICY = 
  functor (type t) ->
    struct
      let trans : t -> t = (fun (x) -> x);
    end;

module policy2 : POLICY =
  functor (type t) ->
    struct
      let trans : t -> t = fun (x) -> x;
    end;

module type FOO = 
  sig
    val trans : a -> [a];
    type a = int;
  end;

module type POLICY = 
  forall t. 
    sig
      val trans : t -> [t]; 
    end;
