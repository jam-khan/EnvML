module type POLICY = 
  forall t. sig val trans : t -> [t];; end;;

module type FOO = 
  sig
    type a = int;;
    val trans_int : a;;
  end;;

module policy1 : POLICY = 
  functor (type t)
    let trans : t -> [t] = (fun (x) -> [x]);;
  end;;

module policy2 : POLICY =
  functor (type t)
    let trans : t -> [t] = fun (x) -> [];;
  end;;

module foo : POLICY ->m FOO =
  functor (m : POLICY) ->
    struct
      type a = int;;
      let trans_int : a -> [a] = (m @ int).trans;;
    end;;

let comp : {f : int -> [int], x : int} -> [int] = 
    fun (env) -> box [e = env] in e.f(e.x);;

let result1 : int = comp({f = foo(policy1).trans_int, x = 42});;
let result2 : int = comp({f = foo(policy2).trans_int, x = 42});;