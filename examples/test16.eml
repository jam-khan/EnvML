type Shape = Circle : int | Square : {w : int, h : int};

let a = Circle(2) :: Shape;
let b = Square({w = 3, h = 4}) :: Shape;

let area : Shape -> int =
  fun (s : Shape) ->
    case s of <Circle=r> => r * r | <Square=dim> => dim.w * dim.h;

let n = area (b);
type Addr = Physical : {firstlast : string} | Virtual : {name : string};

let getName : Addr -> string =
  fun (a : Addr) ->
    case a of <Physical=x> => x.firstlast | <Virtual=y> => y.name;

let addr = Virtual({name = "Hello"}) :: Addr;
let s = getName (addr);


