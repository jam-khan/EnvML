import Database

open Database in 
    type config = { db_type : string; host : string };;

    let get_database =
        fun (config': config) ->
            switch config.db_type with
            | "postgres"    -> postgres_connect config.host "mydb"
            | "mysql"       -> mysql_connect config.host "mydb"
            | _             -> error "Wrong db";;

    let config1 = { db_type = "mysql"; host = "localhost" };;

    let db = get_database config1;;
