(* Safe module concatenation *)

module type M = 
  sig
    type t = bool;;
    yes : t;;
    no  : t;;
    choose : t -> t -> t;;
  end;;

module type N =
  sig
    type t = int;;
    inc  : t -> t;;
  end;;

module m : M =
  struct
    type t = bool;;
    yes = true;;
    no = false;;
    choose (l : t) (r : t) = if l then r else l;;
  end;;

module n : N =
  struct
    type t = int;;
    inc (x : t) = x + 1;;
  end;;

let M_N : M ++ N |> (bool -> (int -> int)) =
    with (m ++ n) in
      fun (b : bool) ->
        fun (x : t) ->
          if b == Yes then inc(x) else x
