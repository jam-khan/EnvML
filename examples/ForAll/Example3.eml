(* Contextual Polymorphism with first-class modules *)

module type ENV = 
  sig (t : type)
    val x : t
  end;;

let get_x_int : ENV @int -> int =
  fun (env : ENV @int) ->
    box env in (x :: t');;

let get_x_bool : ENV @bool -> bool =
  fun (env : ENV @bool) ->
    box env in (x :: bool);;

let env_int  : ENV @int  = struct let x = 42 end;;
let env_bool : ENV @bool = struct let x = true end;;

let res1 : int  = (get_x_int env_int);;  (* 42 *)
let res2 : bool = (get_x_bool env_bool);; (* true *)