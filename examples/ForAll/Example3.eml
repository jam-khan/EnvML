(* Example 3: Interesting Sandboxing *)

let SECRET : INT = 3141;;

module type POLICY = 
  forall t. sig log : t -> () end;;

module guest_policy : POLICY =
  struct (t: type)
    log : t -> () = 
      fun msg -> print msg;;
  end;;

(* Type check: Pass *)
let result : () =
  box guest_policy @string in 
    log("Printing...");;

(* Type check: Fail *)
let leak : () =
  box guest_policy @int in
    log(SECRET);;