(* Example 1: Contextual Polymorphism with first-class modules *)

type ENV = forall t. sig val id : t -> t end;;

module env : ENV =
  functor (t : Type)
    val id : t -> t = fun x -> x;;
  end;;

let int_result : int    =
  with env @int in id(1);;
let bool_result : bool  =
  with env @bool in id(true);;