(* Safe module concatenation *)
module type M = 
  sig
    type t = bool;;
    yes : t;;
    no  : t;;
    choose : t -> t -> t;;
  end;;

module m : M =
  struct
    type t   = bool;;
    yes : t  = true;;
    no  : t  = false;;
    choose : t -> t -> t = fun l r -> if l then r else l;;
  end;;

type INC = int -> int;;
let inc  : INC = fun x -> x + 1;;

type M3 = ctx M, INC;;
let m3 : M3 = env m, inc;;

let M_N : M3 |> (bool -> INC) =
    box m3 in
      (fun b ->
        (fun x -> if b == Yes then inc(x) else x
        ):: INC
      ) :: (bool -> INC);;
