(* Manifest types and Type Equalities *)

module type ENV = 
  sig 
    type t = int;;
    inc : t -> t;;
  end;;

functor env (i : int) : ENV =
  struct
    type t = int;;
    inc (x : int) = x + i;;
  end;;

let id1 : int -> int =
  with env (0) in
    fun (x : t) -> inc (x);;

let id2 : ENV |> int -> int =
  with env (0) in
    fun (x : t) -> inc (x);;