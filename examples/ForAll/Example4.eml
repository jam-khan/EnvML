(* Safe module concatenation *)

module type M = 
  sig
    type t = bool;;
    yes : t;;
    no  : t;;
    choose : t -> t -> t;;
  end;;

module m : M =
  struct
    type t   = bool;;
    yes : t  = true;;
    no  : t  = false;;
    choose : t -> t -> t = fun l r -> if l then r else l;;
  end;;

module type N =
  sig
    type l = int;;
    inc : l -> l;;
  end;;

module n : N =
  struct
    type l = int;;
    inc : l -> l = fun x -> x + 1;;
  end;;

let M_N : ctx M, N |> (bool -> (int -> int)) =
    box env m, n in
      (fun b ->
        (fun x -> if b == Yes then inc(x) else x
        ):: (l -> l)
      ) :: (bool -> (l -> l));;
