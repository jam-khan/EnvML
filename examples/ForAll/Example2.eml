(* Example 2: Interesting Sandboxing *)

let SECRET : INT = 3141;;

module type POLICY = 
  sig log : forall t. t -> () end;;

module guest_policy : POLICY =
  struct
    log : forall t. t -> () = 
        fun (msg : t) -> print msg
  end;;

(* Type check: Pass *)
let result : POLICY |> () =
  box guest_policy in 
    log("Printing...");;

(* Type check: Fail *)
let leak : POLICY |> () =
  box guest_policy in
    log(SECRET);;
