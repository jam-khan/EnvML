-- Example 2: Manifest types and Type Equalities

module type ENV = 
  sig 
    type t = int;;
    inc : t -> t;;
  end;;

--functor env (i : int) : ENV =
--  struct
--    type t = int;;
--    inc (x : int) = x + i;;
--  end;;

module let env : int ->m ENV = 
    functor (i : int) ->
        struct 
            type t = int;;
            let inc (x : t) = x + i;;
        end;;

let id1 : int -> int =
  box env (0) in
    fun (x : t) -> inc (x);;

let id2 : ENV |> int -> int =
  box env (0) in
    fun (x : t) -> inc (x);;
