
let ls1 : int = box [impl = foo(policy1).f] in impl(42);
let ls2 : int = box [impl = foo(policy2).f] in impl(42);

module foo : POLICY ->m FOO =
  functor (m : POLICY) ->
    struct
      let f : a -> [a] = [m @ int].trans;
      type a = int;
    end;

module policy1 : POLICY = 
  functor (type t) ->
    struct
      let trans : t -> t = (fun (x) -> x);
    end;

module policy2 : POLICY =
  functor (type t) ->
    struct
      let trans : t -> t = fun (x) -> x;
    end;

module type FOO = 
  sig
    val f : a -> [a];
    type a = int;
  end;

module type POLICY = 
  forall t. 
    sig
      val trans : t -> t; 
    end;
