%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% METAVARIABLES

metavar i, l, x, y, z, n ::= {{ coq nat }}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% GRAMMAR 

grammar


typ, A {{ tex A }}, B {{ tex B }}, C {{ tex C }}, D {{ tex D }}, F {{ tex \Gamma_1 }}, G {{ tex \Gamma }}, I {{ tex I }}, O {{ tex O }}, char {{ tex \mathsf{Char} }}, bool {{ tex \mathsf{Bool} }}:: 't_' ::= {{ com types }}
  | int            ::  :: int     {{ tex \mathsf{Int}  }} {{ com int }} 
  | Top            ::  :: top     {{ com top }}
  | A -> B         ::  :: arrow   {{ com function types }}
  | A & B          ::  :: and     {{ com intersection }}
  | { l : A }      ::  :: rcd       
  | Ref A          ::  :: tref    {{ tex \text{Ref} \, [[A]] }}
  | lookup A n     :: M:: lookup  {{ tex \mathsf{lookup}([[A]], [[n]])  }}
  | slookup Ga n   :: M:: slookup  {{ tex [[Ga]][ [[n]] ]  }}
  | | Ga |         :: M:: trans   {{ tex | [[Ga]] |  }}
  | | G |          :: M:: otrans   {{ tex | [[G]] |  }}

mode, m {{ tex m }} :: 'm_' ::= {{ com Function modes }} 
  | -             ::   :: minus {{ tex \bullet  }}
  | +             ::   :: plus  {{ tex \circ  }}  

exp, e {{ tex e }}, f {{ tex f }}, p {{ tex p }}, w {{ tex w }}, v {{ tex v }}, vl {{ tex v_{\lambda} }}, V {{ tex V }}, s {{ tex s }}, c {{ tex c }}, Cl {{ tex C }}, u {{ tex u }}, q {{ tex q }}, r {{ tex r }}, t {{ tex t }}, o {{ tex o }}, one_e {{ tex 1 }}, two_e {{ tex 2 }}, true_e {{ tex \mathsf{true} }}, zero {{ tex \underline{0} }} , varx {{tex x}}, emptys {{tex \emptyset }}, z {{tex z}}, a {{ tex a}}, b {{tex b}}, x_e {{ tex x }},f_e {{ tex f }}, y_e {{ tex y }}, z_e {{ tex z }}, vone {{tex \underline{1} }}, vzero {{tex \underline{0} }}, varl {{tex \underline{l} }}, int42 {{tex 42 }}, int3 {{tex 3 }}, int4 {{tex 4 }}, int10 {{tex 10 }} :: 'e_'  ::=      
  | ctx                ::  :: ctx  {{ tex \textsf{?}  }}
  | T                  ::  :: unit 
  | x                  ::  :: rvar {{tex [[x]]}}
  | var n              ::  :: var  {{ tex \underline{[[n]]} }}
  | lit i              ::  :: lit  {{ tex [[i]] }}
  | \ A . e            ::  :: lam  {{ tex [[\]]{[[A]]}.\,[[e]] }}
  | \ x :  A . e            ::  :: nlam  {{ tex [[\]][[x]]:[[A]].\,[[e]] }}
  | \ x . e            ::  :: nutlam  {{ tex [[\]][[x]].\,[[e]] }}
  | \ . e              ::  :: utlam {{ tex [[\]].[[e]] }}
  % | [ e1 , e2 ]        ::  :: bbox   {{ tex [[e1]] \triangleright [[e2]] }} 
  | e1 |> e2           ::  :: box   {{ tex [[e1]] \triangleright [[e2]] }} 
  | < e1 , \ A . e >   ::  :: clos  {{ tex \langle[[e1]], [[\]] [[A]] .\,[[e]] \rangle }} 
  | << e1 ,  e >>      ::  :: utclos  {{ tex \langle[[e1]], [[\]].[[e]] \rangle }} 
  | e1 e2              ::  :: app     {{ com applications }}
  | e1 ,, e2           ::  :: merge   {{ com merge }}
  | { l = e }          ::  :: rec     
  | ;                 ::  :: space    {{ tex \, }}     
  | { e / e1 }         ::  :: envv    {{ tex \{[[e]]/[[e1]]\} }}       
  | e - l              ::  :: sel     {{ tex [[e]].[[l]] }}
  | e . n              ::  :: proj    {{ tex [[e]].[[n]] }}
  | ref e              ::  :: ref     {{ tex \text{ref} \,[[e]]}}
  | ! e                ::  :: deref   {{ tex ! [[e]]}}
  | e1 := e2           ::  :: assign  {{ tex [[e1]] := [[e2]]}}
  | ( e )              :: S:: paren   {{ coq ([[e]]) }}
  | F [ e ]              :: M:: evalctx {{ tex F [ [[e]] ]  }}
  | | e |              :: M:: compile {{ tex | [[e]] |  }}
  | C | e |            :: M:: compilec {{ tex \bra{[[e]]}_{c}  }}
  | S | e |            :: M:: compiles {{ tex \bra{[[e]]}_{s}  }}
  | lookup v x         :: M:: lookup {{ tex \mathsf{lookupv}([[v]], [[x]])  }}
  | clos t s           :: M:: rclos {{tex [[t]] [ [[s]] ] }}
  | t + s              :: M:: ccons {{tex [[t]] \cdot [[s]] }}
  | vs                 :: M:: vs {{tex v_1 \cdots v_n \cdots v_m }}
  | index v x          :: M:: cindex {{ tex [[v]]_[[x]]  }}
  | e1 [ e2 ~> e3 ]    :: M:: subst   
  | e1 [ e2 / e3 ]     :: M:: subst2   
  | sig e1 e2 e3       :: M:: sigma  {{ tex \substf([[e1]],[[e2]],[[e3]]) }}
  | e in V ( A )       :: M:: sem {{ tex [[e]] \in \sem{[[A]]} }}
  | e1 [ e2 ]          :: M:: ebox {{ tex [[e1]] \bra{[[e2]]} }}
  | [ e2 ]             :: M:: sbox {{ tex \bra{[[e2]]} }}
  | { e } m            ::  :: eilam     {{ tex \{ [[e]] \}^[[m]] }} {{ com lam }}
 

sctx, Ga {{ tex \Gamma_{\lambda} }} :: 'sctx_' ::= 
  | []            ::  :: empty    {{ tex \cdot }}  
  | Ga , A   ::  :: cons     {{ tex [[Ga]], [[A]]}}

loc, Sig {{ tex \Sigma }} :: 'loc_' ::= 
  | []            ::  :: empty    {{ tex \cdot }}  
  | Sig , o : A   ::  :: cons     {{ tex [[Sig]], [[o]]:[[A]]}}
  
sto, mu {{ tex \mu }} :: 'sto_' ::= 
  | []            ::  :: empty    {{ tex \cdot }}  
  | mu , o = v    ::  :: cons     {{ tex [[mu]], [[o]]=[[v]]}}
  | mu [ o ~> v ] :: M:: subst   

parsing
  t_arrow <= t_and
  t_arrow right t_arrow
  e_rclos <= e_ccons
  e_sem <= e_box


% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% %% GRAMMAR  (non LNgen portion)

grammar


terminals :: 'terminals_' ::=
  | |>           ::  :: box        {{ tex \triangleright}}
  | \            ::  :: lambda     {{ tex \lambda }}
  | ~>           ::  :: subst      {{ tex \mapsto }}
  | ->           ::  :: arrow      {{ tex \rightarrow }}
  | ~->          ::  :: sarrow     {{ tex \rightsquigarrow }}
  | -->          ::  :: red        {{ tex \hookrightarrow }}
  | -->>          ::  :: mred      {{ tex \hookrightarrow^* }}
  | <=           ::  :: check      {{ tex \Leftarrow }}
  | =>           ::  :: infer      {{ tex \Rightarrow }}
  | <=>          ::  :: mode       {{ tex \Leftrightarrow }}
  | ==>          ::  :: ptype      {{ tex \Longrightarrow }}
  | |->          ::  :: switch     {{ tex \mapsto }}
  | |-           ::  :: turnstile  {{ tex \vdash }}
  | |=           ::  :: dash2      {{ tex \models }}
  | T            ::  :: t          {{ tex \varepsilon }}
  | Top          ::  :: top        {{ tex \varepsilon  }} 
  | int          ::  :: int        {{ tex \mathsf{Int}  }}
  | ,,           ::  :: Merge      {{ tex \fatcomma  }}
  | &            ::  :: And        {{ tex \, \& \, }}
  | :            ::  :: Typ        {{ tex : }}
  | in           ::  :: in         {{ tex \in }}
  | ;            ::  :: ctxAnd     {{ tex ; }}
  | topLike      ::  :: topLike    {{ tex \mathsf{TOPLIKE} }}
  | <*>          ::  :: disjointSpec    {{ tex * }}
  | **           ::  :: disjoint        {{ tex * }}
  | ~            ::  :: consistencySpec {{ tex \sim }}
  | ~~           ::  :: consistent {{ tex \approx }}
  | <            ::  :: lang      {{ tex \langle}}
  | >            ::  :: rang  {{ tex \rangle}}
  | <            ::  :: osub       {{ tex \leq }}
  | topl         ::  :: topl       {{ tex \rceil }}
  | topr         ::  :: topr       {{ tex \lceil }}
  | extends      ::  :: extends    {{ tex \supseteq }}


formula :: 'formula_' ::=
  | judgement                ::   :: judgement
  | not formula              :: M :: not {{ tex \neg [[formula]]  }}
  | ( formula )              :: M :: brackets {{ tex ([[formula]]\!) }}  
  | Sig |- mu                ::   :: sto_typing
  | Sig1 extends Sig2        ::   :: extends
  | o : A in Sig             ::   :: inSig
  | o = v in mu              ::   :: inmu
  | o notin mu               ::   :: notinmu
    {{ tex [[o]] \notin dom([[mu]]) }}
  | o in mu                  ::   :: oinmu
    {{ tex [[o]] \in dom([[mu]]) }}
  | e1 = e2                  :: M :: exp_eq
  | A = B                    :: M :: typ_eq
  | |- e                     :: M :: islc   {{ tex [[|-]]_{\lambda} [[e]]  }}
  | |= e                     :: M :: islrh   {{ tex [[|-]]_{ \widehat{\rho} } [[e]]  }}
  | |- A                     :: M :: islct  {{ tex [[|-]]_{\lambda} [[A]]  }}
  | l notin A          :: M:: notlin {{ tex [[l]] \notin label([[A]]) }}
  | v |= e : A         :: M:: semtyp {{ tex [[v]][[|=]][[e]]:[[A]] }}
  | G |= e : A         :: M:: semtyp2 {{ tex [[G]][[|=]][[e]]:[[A]] }}


