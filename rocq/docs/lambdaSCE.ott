v1[l] ~-> v2
------------------------------------------ :: sel
v |- mu; v1 - l --> mu; v2

o notin mu   
------------------------------------------ :: refv
v |- mu ; ref v1  --> mu , o = v1 ; o

o = v1 in mu   
------------------------------------------ :: deref
v |- mu ; !o  --> mu ; v1

o in mu
------------------------------------------ :: assign
v |- mu ; o := v1  --> mu [ o ~> v1 ] ; T


